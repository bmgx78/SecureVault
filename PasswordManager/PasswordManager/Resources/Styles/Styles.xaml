<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:converters="clr-namespace:PasswordManager.Converters">

    <!-- Value Converters -->
    <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
    <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
    <converters:IntGreaterThanZeroConverter x:Key="IntGreaterThanZeroConverter"/>
    <converters:BoolToStringConverter x:Key="BoolToStringConverter"/>
    <converters:PercentToDoubleConverter x:Key="PercentToDoubleConverter"/>
    <converters:StrengthToColorConverter x:Key="StrengthToColorConverter"/>
    <converters:TitleToInitialConverter x:Key="TitleToInitialConverter"/>

    <!-- Global Styles -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource ColorBase}"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource ColorText}"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource ColorText}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource ColorMuted}"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ColorBlue}"/>
        <Setter Property="TextColor" Value="{StaticResource ColorBase}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ColorSurface}"/>
        <Setter Property="TextColor" Value="{StaticResource ColorText}"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource ColorBase}"/>
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource ColorText}"/>
        <Setter Property="Shell.TabBarBackgroundColor" Value="#181825"/>
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource ColorText}"/>
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource ColorBlue}"/>
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource ColorMuted}"/>
    </Style>

</ResourceDictionary>
