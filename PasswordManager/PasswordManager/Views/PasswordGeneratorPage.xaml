<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PasswordManager.ViewModels"
             x:Class="PasswordManager.Views.PasswordGeneratorPage"
             Title="Password Generator"
             BackgroundColor="#1E1E2E">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Generated password display -->
            <Frame BackgroundColor="#313244" BorderColor="#89B4FA" CornerRadius="12" Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding GeneratedPassword}"
                           FontSize="18" FontFamily="OpenSansRegular"
                           TextColor="#CDD6F4" LineBreakMode="CharacterWrap"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    <ProgressBar Progress="{Binding PasswordStrength, Converter={x:StaticResource PercentToDoubleConverter}}"
                                 ProgressColor="{Binding PasswordStrength, Converter={x:StaticResource StrengthToColorConverter}}"
                                 HeightRequest="6"/>
                    <Label Text="{Binding PasswordStrengthLabel}" FontSize="12" TextColor="#6C7086"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Copy / Generate buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Text="📋 Copy" Command="{Binding CopyCommand}"
                        BackgroundColor="#313244" TextColor="#89B4FA"
                        BorderColor="#89B4FA" BorderWidth="1" CornerRadius="10"/>
                <Button Grid.Column="1" Text="⚡ Regenerate" Command="{Binding GenerateCommand}"
                        BackgroundColor="#89B4FA" TextColor="#1E1E2E" FontAttributes="Bold" CornerRadius="10"/>
            </Grid>

            <Label Text="{Binding CopiedMessage}" TextColor="#A6E3A1" HorizontalOptions="Center"
                   IsVisible="{Binding CopiedMessage, Converter={x:StaticResource StringNotEmptyConverter}}"/>

            <!-- Mode toggle -->
            <Frame BackgroundColor="#313244" BorderColor="#45475A" CornerRadius="12" Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Use Passphrase Instead" TextColor="#CDD6F4" VerticalOptions="Center"/>
                    <Switch Grid.Column="1" IsToggled="{Binding UsePassphrase}" OnColor="#89B4FA"/>
                </Grid>
            </Frame>

            <!-- Password options -->
            <Frame BackgroundColor="#313244" BorderColor="#45475A" CornerRadius="12" Padding="16"
                   IsVisible="{Binding UsePassphrase, Converter={x:StaticResource InvertBoolConverter}}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="PASSWORD OPTIONS" TextColor="#6C7086" FontSize="11" FontAttributes="Bold"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Length, StringFormat='Length: {0}'}" TextColor="#CDD6F4" VerticalOptions="Center"/>
                        <Slider Grid.Column="1" Minimum="8" Maximum="64" Value="{Binding Length}"
                                WidthRequest="150" ThumbColor="#89B4FA" MinimumTrackColor="#89B4FA"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Uppercase (A-Z)" TextColor="#CDD6F4" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding IncludeUppercase}" OnColor="#89B4FA"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Numbers (0-9)" TextColor="#CDD6F4" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding IncludeDigits}" OnColor="#89B4FA"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Symbols (!@#...)" TextColor="#CDD6F4" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding IncludeSymbols}" OnColor="#89B4FA"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Exclude Ambiguous (0Oo1lI)" TextColor="#CDD6F4" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding ExcludeAmbiguous}" OnColor="#89B4FA"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Passphrase options -->
            <Frame BackgroundColor="#313244" BorderColor="#45475A" CornerRadius="12" Padding="16"
                   IsVisible="{Binding UsePassphrase}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="PASSPHRASE OPTIONS" TextColor="#6C7086" FontSize="11" FontAttributes="Bold"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{Binding PassphraseWords, StringFormat='Words: {0}'}" TextColor="#CDD6F4" VerticalOptions="Center"/>
                        <Stepper Grid.Column="1" Minimum="3" Maximum="8" Value="{Binding PassphraseWords}"/>
                    </Grid>
                    <Label Text="Separator" TextColor="#CDD6F4"/>
                    <Frame BackgroundColor="#45475A" BorderColor="Transparent" CornerRadius="8" Padding="4">
                        <Entry Text="{Binding PassphraseSeparator}" MaxLength="3"
                               TextColor="#CDD6F4" BackgroundColor="Transparent"/>
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <!-- History -->
            <Label Text="RECENT PASSWORDS" TextColor="#6C7086" FontSize="11" FontAttributes="Bold" Margin="0,8,0,0"/>
            <CollectionView ItemsSource="{Binding PasswordHistory}" HeightRequest="200">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Frame BackgroundColor="#313244" BorderColor="Transparent" CornerRadius="8"
                               Margin="0,3" Padding="12,8">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PasswordGeneratorViewModel}}, Path=CopyHistoryItemCommand}"
                                    CommandParameter="{Binding}"/>
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding}" TextColor="#6C7086" FontSize="13"
                                       LineBreakMode="TailTruncation"/>
                                <Label Grid.Column="1" Text="📋" FontSize="14"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
